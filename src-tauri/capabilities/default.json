{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "dialog:allow-open",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "python-sidecar",
          "cmd": "python",
          "args": true
        }
      ]
    },
    "shell:allow-stdin-write",
    "fs:default",
    "fs:allow-read",
    "fs:allow-exists"
  ]
}
